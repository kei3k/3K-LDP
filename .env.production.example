# Production env for the VPS Express server (server/index.js).
# Actual file lives at /root/tool-nam/.env on the VPS — never commit real values.

PORT=5175
NODE_ENV=production

# Vertex AI (Google Cloud) — GCP service account for customer Nam
VERTEX_KEY_FILE=/root/secrets/nam-vertex-key.json
VERTEX_PROJECT_ID=project-69c36692-1143-4d42-847
VERTEX_REGION=global

# Zumia SSO (reused Supabase project — same values as backend/.env on main Zumia app)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Comma-separated allowlist of emails permitted into this workspace
NAM_ALLOWED_EMAILS=kei.marketer@gmail.com,cos-debug@zumia.space

# Extra hostnames allowed through /api/fetch-url, beyond the built-in defaults
# (ladipage/webcake/alicdn/1688/shopee/lazada). Comma-separated.
ALLOWED_FETCH_HOSTS=
